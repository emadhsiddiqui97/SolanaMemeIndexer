{
    "name": "orderservice",
    "module": "index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "start": "bun run index.ts",
        "dev": "bun --watch index.ts",
        "test": "bun test",
        "test:worker": "bun test worker.test.js",
        "pm2:start": "pm2 start ecosystem.config.js",
        "pm2:start:prod": "pm2 start ecosystem.config.js --env production",
        "pm2:start:staging": "pm2 start ecosystem.config.js --env staging",
        "pm2:restart": "pm2 restart bun-api-server",
        "pm2:stop": "pm2 stop bun-api-server",
        "pm2:delete": "pm2 delete bun-api-server",
        "pm2:logs": "pm2 logs bun-api-server",
        "pm2:monit": "pm2 monit",
        "pm2:status": "pm2 status",
        "setup": "mkdir -p logs && bun install",
        "health-check": "curl -f http://localhost:3000/api/health || exit 1",
        "load-test": "bun run load-test.js"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/express": "^5.0.1",
        "@types/lodash": "^4.17.16",
        "@types/node": "^24.0.3",
        "typescript": "^5.7.3"
    },
    "dependencies": {
        "@bloxroute/solana-trader-client-ts": "^2.2.7",
        "@coral-xyz/anchor": "^0.30.1",
        "@coral-xyz/borsh": "^0.30.1",
        "@prisma/client": "6.2.1",
        "@pump-fun/pump-swap-sdk": "^0.0.1-beta.33",
        "@solana/web3.js": "^1.98.0",
        "axios": "^1.7.9",
        "base58": "^2.0.1",
        "bn.js": "^5.2.2",
        "bs58": "^6.0.0",
        "chalk": "^5.4.1",
        "cors": "^2.8.5",
        "decimal.js": "^10.6.0",
        "express": "^4.21.2",
        "limiter": "^3.0.0",
        "lodash": "^4.17.21",
        "nodemon": "^3.1.9",
        "pm2": "^5.4.3",
        "prisma": "^6.2.1",
        "progress": "^2.0.3",
        "redis": "^4.7.0",
        "ts-progress": "^0.1.9",
        "winston": "^3.17.0",
        "winston-daily-rotate-file": "^5.0.0"
    },
    "peerDependencies": {
        "typescript": "^5"
    }
