model sniperOrders {
  id               Int    @id @default(autoincrement())
  mint             String
  rayMint          String @map("ray_mint")
  userId           Int    @map("userId")
  strategyId       Int    @map("strategyId")
  decimals         Int
  orderAmountInUsd Float  @map("order_amount_in_usd")
  buyingPrice      Float? @map("buying_price")
  takeProfitPrice  Float? @map("take_profit_price")
  stopLossPrice    Float? @map("stop_loss_price")
  status           String

  // JSON fields for custom types
  initialPrice    Json  @map("initial_price") // stores prices type as {usd: float, native: float}
  finalPrice      Json  @map("final_price") // stores prices type as {usd: float, native: float}
  tokenBuyAmount  Json  @map("token_buy_amount") // stores comparePrices type as {tokens: float, usd: float}
  tokenSellAmount Json  @map("token_sell_amount")
  buyAmount       Json? @map("buy_amount")
  sellAmount      Json? @map("sell_amount") // stores comparePrices type as {tokens: float, usd: float}

  // Timestamps and transaction info
  buyTime         DateTime?         @map("buy_time") // Using BigInt for timestamp
  sellTime        DateTime?         @map("sell_time") // Optional
  buyTxHash       String?           @map("buy_tx_hash") // Optional
  sellTxHash      String?           @map("sell_tx_hash") // Optional
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  token           tokens            @relation(fields: [mint], references: [mint])
  sniperStrategy  sniperStrategies  @relation(fields: [strategyId], references: [id])
  user            users             @relation(fields: [userId], references: [id])
  ray_token       raydium_tokens?   @relation(fields: [rayMint], references: [mint])
  order_analytics order_analytics[]

  @@unique([mint, strategyId, userId])
  // Indexes for better query performance
  @@index([userId])
  @@index([strategyId])
  @@index([mint])
  @@index([status])
  @@map("sniper_orders")
}

model strategies {
  id               Int      @id @default(autoincrement())
  user_id          Int      @unique
  market_cap_min   Decimal? @db.Decimal
  market_cap_max   Decimal? @db.Decimal
  transactions_min Int?
  transactions_max Int?
  buys_min         Int?
  buys_max         Int?
  sells_min        Int?
  sells_max        Int?
  volume_min       Decimal? @db.Decimal
  volume_max       Decimal? @db.Decimal
  tx_min           Int?
  tx_max           Int?
  holding_min      Decimal? @db.Decimal
  holding_max      Decimal? @db.Decimal
  liquidity_min    Decimal? @db.Decimal
  liquidity_max    Decimal? @db.Decimal
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  users            users    @relation(fields: [user_id], references: [id])
}

model user_wallets {
  id          Int      @id @default(autoincrement())
  public_key  String   @unique
  private_key String   @unique
  email       String   @unique
  created_at  DateTime @default(now())
  users       users    @relation(fields: [email], references: [email])
}

model users {
  id                Int                @id @default(autoincrement())
  email             String             @unique
  password          String
  role              Role               @default(VIEWER)
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  sniper_strategies sniperStrategies[]
  strategies        strategies?
  user_wallets      user_wallets?
  sniperOrders      sniperOrders[]
}

model hotTokens {
  id    Int    @id @default(autoincrement())
  mint  String @unique
  token tokens @relation(fields: [mint], references: [mint])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("hot_tokens")
}

enum tierlevel {
  SIGNAL
  HOT
  WARM
  COLD
  RUGGED
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

model order_analytics {
  id              Int          @id @default(autoincrement())
  mint            String
  orderid         Int
  creator_equity  Float        @default(0.0)
  total_supply    Float        @default(0.0)
  total_holders   Int          @default(0)
  market_cap      Float        @default(0)
  creator_balance Float        @default(0)
  sol_volume      Float        @default(0.0)
  token_volume    Float        @default(0.0)
  buy_count       Float        @default(0.0)
  sell_count      Float        @default(0.0)
  total_tx        Float        @default(0.0)
  decimals        Int          @default(6)
  token_volume_bn String?
  sol_volume_bn   String?
  reserve_sol     String?
  reserve_token   String?
  dex             Int?
  is_buy          Boolean?
  sniper_orders   sniperOrders @relation(fields: [orderid], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model HourlyTxAnalytics {
  id           Int      @id @default(autoincrement())
  mint         String
  totalTx      Int      @map("total_tx")
  buyTx        Int      @map("buy_tx")
  sellTx       Int      @map("sell_tx")
  analyticDate DateTime @map("analytic_date") @db.Date
  hour         Int
  firstTxAt    DateTime @map("first_tx_at") @db.Timestamp(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("hourly_tx_analytics")
}

model TxCounter {
  id         Int      @id @default(autoincrement()) @map("id")
  date       DateTime @map("date")
  pumpswapTx Int      @default(0) @map("pumpswap_tx")
  pumpfunTx  Int      @default(0) @map("pumpfun_tx")
  raydiumTx  Int      @default(0) @map("raydium_tx")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("tx_counter")
}
