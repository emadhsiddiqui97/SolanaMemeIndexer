generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model meme_token_test {
  id                Int      @id @default(autoincrement())
  mint              String   @unique
  name              String?
  uri               String?
  symbol            String?
  socials           String[]
  top10holderEquity Float?
  creatorEquity     Float?
  totalSupply       Float?
  // lpBurned  Boolean?
  // lpBurnedAmount Float?
  mintable          Boolean?
  freezeable        Boolean?
  tax               Boolean?
  liquidityLock     Boolean?
  bondingCurve      String? //vault
  creator           String?
  bondingProgress   Float?
  marketCap         Float?
  reserveSol        Float?
  reserveToken      Float?
  status            Int?
  totalHolders      Int?
  buyCount          Int
  sellCount         Int
  updated_at        DateTime
  created_at        DateTime @default(now())
}

model tokens {
  id                   Int             @id @default(autoincrement())
  mint                 String          @unique
  name                 String?
  uri                  String?
  symbol               String?
  socials              String[]
  decimals             Int             @default(6)
  mintable             Boolean         @default(true)
  freezeable           Boolean         @default(true)
  top_10_holder_equity Float           @default(0.0)
  creator              String?
  creator_equity       Float           @default(0.0)
  total_supply         Float           @default(0.0)
  total_holders        Int             @default(0)
  market_cap           Float           @default(0)
  creator_balance      Float           @default(0)
  sol_volume           Float           @default(0.0)
  token_volume         Float           @default(0.0)
  tokenVolumeBN        String?         @map("token_volume_bn")
  solVolumeBN          String?         @map("sol_volume_bn")
  buy_count            Float           @default(0.0)
  sell_count           Float           @default(0.0)
  total_tx             Float           @default(0.0)
  created_at           DateTime        @default(now())
  updated_at           DateTime?       @updatedAt
  hot_monitoring       hot_monitoring?
  pump_tokens          pump_tokens?
  ray_token            raydium_tokens?
  rug_check            rug_score?
  pumpswap_tokens      pumpswapTokens?
  sniperOrders         sniperOrders[]
  tokenPools           tokenPools[]
  pools                pools[]
  hotTokens            hotTokens?
}

model pump_tokens {
  id               Int      @id @default(autoincrement())
  mint             String   @unique
  bonding_curve    String?
  bonding_progress Float?
  reserve_sol      Float    @default(0)
  reserve_token    Float    @default(0)
  buy_count        Int      @default(0)
  sell_count       Int      @default(0)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  token            tokens   @relation(fields: [mint], references: [mint], onDelete: Cascade)
}

model poolTransactions {
  id                 Int      @id @default(autoincrement())
  mint               String
  pool               String
  isBuy              Boolean  @map("is_buy")
  solAmount          Float    @map("sol_amount")
  tokenAmount        Float    @map("token_amount")
  dex                Int
  user               String
  tokenPriceInSol    Float    @map("token_price_in_sol")
  isLiquidityRemoved Boolean? @map("is_liquidity_removed")
  timestamp          Int?
  signature          String
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("pool_transactions")
}

model raydium_tokens {
  id                 Int            @id @default(autoincrement())
  mint               String         @unique
  market_account     String
  reserve_sol        Float
  reserve_token      Float
  lp_burn            Float
  lp_burned          Boolean
  lp_reserve         Float
  liquidity_in_sol   Float          @default(0.0)
  price_in_sol       Float          @default(0.0)
  price_in_usd       Float          @default(0.0)
  liquidity_in_usd   Float          @default(0.0)
  is_quote_vault_sol Boolean        @default(true)
  base_vault         String?
  quote_vault        String?
  created_at         DateTime       @default(now())
  updated_at         DateTime       @updatedAt
  token              tokens         @relation(fields: [mint], references: [mint], onDelete: Cascade)
  sniperOrders       sniperOrders[]
}

model pumpswapTokens {
  id              Int      @id @default(autoincrement())
  mint            String   @unique
  marketAccount   String   @map("market_account")
  reserveSol      String   @map("reserve_sol")
  reserveToken    String   @map("reserve_token")
  lpBurn          String   @map("lp_burn")
  lpBurned        Boolean  @map("lp_burned")
  liquidityInSol  Float    @default(0.0) @map("liquidity_in_sol")
  liquidityInUsd  Float    @default(0.0) @map("liquidity_in_usd")
  priceInSol      Float    @default(0.0) @map("price_in_sol")
  priceInUsd      Float    @default(0.0) @map("price_in_usd")
  isQuoteVaultSol Boolean  @default(true) @map("is_quote_vault_sol")
  baseVault       String?  @map("base_vault")
  quoteVault      String?  @map("quote_vault")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  token           tokens   @relation(fields: [mint], references: [mint], onDelete: Cascade)

  @@map("pumpswap_tokens")
}

model tokenPools {
  id            Int      @id @default(autoincrement())
  mint          String
  poolAddress   String   @unique @map("pool_address")
  dex           String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  signature     String?
  priceInSol    Float    @default(0.0) @map("price_in_sol")
  solReserves   Float    @default(0.0) @map("sol_reserves")
  tokenReserves Float    @default(0.0) @map("token_reserves")
  token         tokens   @relation(fields: [mint], references: [mint], onDelete: Cascade)

  @@map("token_pools")
}

model pools {
  id             Int      @id @default(autoincrement())
  mint           String
  poolAddress    String   @unique @map("pool_address")
  dex            String
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  priceInSol     Float    @default(0.0) @map("price_in_sol")
  priceInUsd     Float    @default(0.0) @map("price_in_usd")
  solReserves    String   @map("sol_reserves")
  tokenReserves  String   @map("token_reserves")
  liquidityInSol Float    @default(0.0) @map("liquidity_in_sol")
  liquidityInUsd Float    @default(0.0) @map("liquidity_in_usd")
  totalTx        Int      @default(0) @map("total_tx")
  buyTx          Int      @default(0) @map("buy_tx")
  sellTx         Int      @default(0) @map("sell_tx")
  token          tokens   @relation(fields: [mint], references: [mint], onDelete: Cascade)
}

model transactions {
  id                   Int      @id @default(autoincrement())
  mint                 String
  is_buy               Boolean
  sol_amount           Float
  token_amount         Float
  status               Int      @default(0)
  dex                  Int
  user                 String
  token_price_in_sol   Float
  is_liquidity_removed Boolean?
  timestamp            Int?
  signature            String   @unique
  created_at           DateTime @default(now())
}

model hot_monitoring {
  id           Int    @id @default(autoincrement())
  mint         String @unique
  sol_volume   Float  @default(0.0)
  token_volume Float  @default(0.0)
  token        tokens @relation(fields: [mint], references: [mint], onDelete: Cascade)
}

model rug_score {
  id                      Int      @id @default(autoincrement())
  created_at              DateTime @default(now())
  mint                    String   @unique
  is_website_valid        Boolean
  has_tweets              Boolean
  number_of_twitters      Int
  not_mintable_risk       Boolean
  not_freeze_risk         Boolean
  not_auto_freeze         Boolean
  permanent_control       Boolean
  has_concerning_metadata Boolean
  liquidity_confirmed     Boolean
  liquidity_level         Boolean
  custom_fees             Boolean
  recent_activity         Boolean
  all_pools               Boolean
  lp_providers            Boolean
  stable_contract         Boolean
  team_wallet_holdings    Boolean
  top_10_holders          Boolean
  tx_24h                  Boolean
  vol_24h                 Boolean
  token                   tokens   @relation(fields: [mint], references: [mint], onDelete: Cascade)
}

model database_performance {
  operation_type String   @db.VarChar(50)
  table_name     String   @db.VarChar(255)
  execution_time Float
  rows_affected  Int?
  query_plan     Json?
  extra_data     Json?
  id             Int      @id @default(autoincrement())
  created_at     DateTime @db.Timestamptz(6)
  updated_at     DateTime @db.Timestamptz(6)

  @@index([id], map: "ix_database_performance_id")
  @@index([operation_type], map: "ix_database_performance_operation_type")
}

model holder_snapshot {
  token_id              Int
  timestamp             DateTime  @db.Timestamptz(6)
  holder_count          Int?
  holder_distribution   Json?
  concentration_metrics Json?
  id                    Int       @id @default(autoincrement())
  created_at            DateTime  @db.Timestamptz(6)
  updated_at            DateTime  @db.Timestamptz(6)
  meme_coin             meme_coin @relation(fields: [token_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([token_id, timestamp], map: "uq_holder_snapshot_token_timestamp")
  @@index([id], map: "ix_holder_snapshot_id")
  @@index([timestamp], map: "ix_holder_snapshot_timestamp")
}

model meme_coin {
  address                  String               @unique(map: "ix_meme_coin_address") @db.VarChar(255)
  name                     String?              @db.VarChar(255)
  symbol                   String?              @db.VarChar(255)
  decimals                 Int?
  total_supply             BigInt?
  creator_address          String?              @db.VarChar(255)
  creation_tx_hash         String?
  contract_verified        Boolean?
  contract_code            String?
  contract_analysis        Json?
  is_active                Boolean
  monitoring_status        String?              @db.VarChar(50)
  circulating_supply       BigInt?
  burned_supply            BigInt?
  bonding_curve_address    String?              @db.VarChar(255)
  bonding_curve_state      Json?
  is_curve_complete        Boolean?
  tokens_left              BigInt?
  bonding_curve_completion Float?
  king_of_hill_progress    Float?
  price_usd                Float?
  market_cap_usd           Float?
  volume_24h_usd           Float?
  liquidity                Float?
  liquidity_pairs          Json?
  holder_count             Int?
  holder_distribution      Json?
  top_holders              Json?
  risk_score               Float?
  risk_factors             Json?
  whale_holdings           Float?
  smart_money_flow         Float?
  holder_growth_rate       Float?
  launch_date              DateTime?            @db.Timestamptz(6)
  created_at               DateTime             @db.Timestamptz(6)
  id                       Int                  @id @default(autoincrement())
  updated_at               DateTime             @db.Timestamptz(6)
  holder_snapshot          holder_snapshot[]
  token_metadata           token_metadata?
  token_price              token_price[]
  token_tier               token_tier[]
  trading_volume           trading_volume[]
  wallet_analysis          wallet_analysis[]
  wallet_transaction       wallet_transaction[]

  @@index([id], map: "ix_meme_coin_id")
}

model r_p_c_performance {
  endpoint      String   @db.VarChar(255)
  request_type  String   @db.VarChar(50)
  response_time Float
  success       Boolean
  error_type    String?  @db.VarChar(255)
  error_message String?  @db.VarChar
  extra_data    Json?
  id            Int      @id @default(autoincrement())
  created_at    DateTime @db.Timestamptz(6)
  updated_at    DateTime @db.Timestamptz(6)

  @@index([endpoint], map: "ix_r_p_c_performance_endpoint")
  @@index([id], map: "ix_r_p_c_performance_id")
}

model task_performance {
  task_name      String   @db.VarChar(255)
  execution_time Float
  success        Boolean
  error_message  String?  @db.VarChar
  memory_usage   Float?
  cpu_usage      Float?
  extra_data     Json?
  id             Int      @id @default(autoincrement())
  created_at     DateTime @db.Timestamptz(6)
  updated_at     DateTime @db.Timestamptz(6)

  @@index([id], map: "ix_task_performance_id")
  @@index([task_name], map: "ix_task_performance_task_name")
}

model tier_alert {
  token_tier_id   Int
  alert_type      String     @db.VarChar(50)
  severity        String     @db.VarChar(20)
  message         String
  resolved        Boolean?
  resolved_at     DateTime?  @db.Timestamptz(6)
  resolution_note String?
  alert_data      Json?
  id              Int        @id @default(autoincrement())
  created_at      DateTime   @db.Timestamptz(6)
  updated_at      DateTime   @db.Timestamptz(6)
  token_tier      token_tier @relation(fields: [token_tier_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([id], map: "ix_tier_alert_id")
}

model tier_transition {
  token_tier_id    Int
  from_tier        tierlevel?
  to_tier          tierlevel
  transition_time  DateTime   @db.Timestamptz(6)
  confidence_score Float?
  reason           String?
  metrics_snapshot Json?
  id               Int        @id @default(autoincrement())
  created_at       DateTime   @db.Timestamptz(6)
  updated_at       DateTime   @db.Timestamptz(6)
  token_tier       token_tier @relation(fields: [token_tier_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([id], map: "ix_tier_transition_id")
}

model token_metadata {
  token_id        Int       @unique
  website         String?   @db.VarChar(255)
  telegram        String?   @db.VarChar(255)
  twitter         String?   @db.VarChar(255)
  discord         String?   @db.VarChar(255)
  description     String?
  tags            Json?
  custom_metadata Json?
  id              Int       @id @default(autoincrement())
  created_at      DateTime  @db.Timestamptz(6)
  updated_at      DateTime  @db.Timestamptz(6)
  meme_coin       meme_coin @relation(fields: [token_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([id], map: "ix_token_metadata_id")
}

model token_price {
  token_id       Int
  timestamp      DateTime  @db.Timestamptz(6)
  price_usd      Float
  volume_usd     Float?
  market_cap_usd Float?
  liquidity_usd  Float?
  id             Int       @id @default(autoincrement())
  created_at     DateTime  @db.Timestamptz(6)
  updated_at     DateTime  @db.Timestamptz(6)
  meme_coin      meme_coin @relation(fields: [token_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([token_id, timestamp], map: "uq_token_price_token_timestamp")
  @@index([id], map: "ix_token_price_id")
  @@index([timestamp], map: "ix_token_price_timestamp")
}

model token_tier {
  token_id             Int
  token_address        String            @unique(map: "ix_token_tier_token_address") @db.VarChar(255)
  current_tier         tierlevel
  previous_tier        tierlevel?
  check_frequency      Int
  is_active            Boolean?
  is_monitoring_paused Boolean?
  processing_priority  Int?
  last_checked         DateTime?         @db.Timestamptz(6)
  next_check_at        DateTime?         @db.Timestamptz(6)
  tier_updated_at      DateTime?         @db.Timestamptz(6)
  confidence_score     Float?
  market_cap           BigInt?
  volume_24h           BigInt?
  holder_count         Int?
  price_change_24h     Float?
  tier_history         Json?
  monitoring_notes     String?
  id                   Int               @id @default(autoincrement())
  created_at           DateTime          @db.Timestamptz(6)
  updated_at           DateTime          @db.Timestamptz(6)
  tier_alert           tier_alert[]
  tier_transition      tier_transition[]
  meme_coin            meme_coin         @relation(fields: [token_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([current_tier], map: "ix_token_tier_current_tier")
  @@index([id], map: "ix_token_tier_id")
}

model trading_volume {
  token_id           Int
  timestamp          DateTime  @db.Timestamptz(6)
  volume_usd         Float?
  trade_count        Int?
  buyer_count        Int?
  seller_count       Int?
  whale_volume       Float?
  smart_money_volume Float?
  id                 Int       @id @default(autoincrement())
  created_at         DateTime  @db.Timestamptz(6)
  updated_at         DateTime  @db.Timestamptz(6)
  meme_coin          meme_coin @relation(fields: [token_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([token_id, timestamp], map: "uq_trading_volume_token_timestamp")
  @@index([id], map: "ix_trading_volume_id")
  @@index([timestamp], map: "ix_trading_volume_timestamp")
}

model wallet_analysis {
  token_id            Int
  analysis_timestamp  DateTime  @db.Timestamptz(6)
  risk_score          Float?
  early_entries       Json?
  wallet_clusters     Json?
  coordinated_actions Json?
  high_risk_wallets   Json?
  id                  Int       @id @default(autoincrement())
  created_at          DateTime  @db.Timestamptz(6)
  updated_at          DateTime  @db.Timestamptz(6)
  meme_coin           meme_coin @relation(fields: [token_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([id], map: "ix_wallet_analysis_id")
}

model wallet_transaction {
  token_id         Int
  token_address    String    @db.VarChar(255)
  wallet_address   String    @db.VarChar(255)
  transaction_type String    @db.VarChar(50)
  amount           Float
  price            Float
  timestamp        DateTime  @db.Timestamptz(6)
  mcap_at_time     Float?
  id               Int       @id @default(autoincrement())
  created_at       DateTime  @db.Timestamptz(6)
  updated_at       DateTime  @db.Timestamptz(6)
  meme_coin        meme_coin @relation(fields: [token_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([token_id, timestamp], map: "idx_wallet_token_time")
  @@index([id], map: "ix_wallet_transaction_id")
  @@index([token_address], map: "ix_wallet_transaction_token_address")
  @@index([transaction_type], map: "ix_wallet_transaction_transaction_type")
  @@index([wallet_address], map: "ix_wallet_transaction_wallet_address")
}

model permissions {
  id                 Int      @id @default(autoincrement())
  role               Role     @unique
  filter_permissions Json
  trade_permissions  Json
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
}

model rug_standards {
  id         Int      @id @default(autoincrement())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  standard   Json?
}

model sniperStrategies{
  id Int @id @default(autoincrement())
  name String @default(uuid())
  userId Int @map("userId")
  mintable Boolean @default(false)
  freezeable Boolean @default(false)
  liquidityAmount Float @default(80.0) @map("liquidity_amount")
  top10HoldingPercentage Float @default(10.0) @map("top_10_holding_percentage")
  bundlePercentage Float @default(5.0) @map("bundle_percentage")
  orderAmountInSol Float @default(0.0) @map("order_amount_in_sol")
  maxBuyVolume Float @default(5.0) @map("max_buy_volume")
  profit Float? @default(10.0)
  stopLoss Float? @default(0.95) @map("stop_loss")
  active Boolean @default(false)
  market_cap           Float?
  volume           Float?
  total_tx           Float?
  totalHolders        Int? @map("total_holders")
  hasSocials  Boolean? @map("has_socials")
  hasTelegram Boolean? @map("has_telegram")
  hasWebsite  Boolean? @map("has_website")
  isOnChain Boolean @default(false) @map("is_on_chain")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")
  sniperOrders           sniperOrders[]
  user users @relation(fields: [userId], references: [id])
 @@map("sniper_strategies")
}

